# Vite development server
# These values are optional because vite.config.ts provides these defaults.
PORT=5173
BASE_PATH=/

# Local Cloudflare Worker API
# Development already defaults to http://127.0.0.1:8787 when this is omitted.
VITE_NIGHTFORCE_API_BASE_URL=http://127.0.0.1:8787

# Midnames / .night identity integration
# Midnames is intentionally pinned to Midnight preprod in the application code.
VITE_FEATURE_MIDNAMES=true
VITE_ENABLE_INTERACTIVE_MIDNAMES=true

# Midnight wallet profile flow
# Temporarily disabled while the federated mainnet contract deployment
# and wallet integration are being completed.
VITE_ENABLE_MIDNIGHT_PROFILE_FLOW=false

# Accepted modes: local-readonly, preprod-write, mainnet-write
# Keep local-readonly for normal development and Midnames review.
VITE_NIGHTFORCE_APP_MODE=local-readonly

# Accepted network IDs: undeployed, preprod, mainnet
VITE_MIDNIGHT_NETWORK_ID=undeployed

# preprod-write and mainnet-write remain in the codebase for ongoing
# integration work. Neither should currently be treated as a supported
# end-user flow for new-profile creation or existing wallet-linked access.
#
# The Midnames .night integration is independent of this wallet gate.

# Visitor activity API logging is optional.
VITE_ENABLE_VISITOR_ACTIVITY_LOGGING=false

# Optional Profile Proof state endpoint override.
# VITE_PROFILE_PROOF_STATE_URL=http://127.0.0.1:4000/api/profile-proof/state?target=preprod

# Optional frontend fallbacks when the Worker does not return a global
# Contact Mode contract address.
# VITE_CONTACT_MODE_GLOBAL_PREPROD_CONTRACT_ADDRESS=
# VITE_CONTACT_MODE_GLOBAL_MAINNET_CONTRACT_ADDRESS=
